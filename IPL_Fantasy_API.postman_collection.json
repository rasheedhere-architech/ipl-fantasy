{
  "info": {
    "name": "IPL Fantasy Backend API (Local)",
    "description": "Endpoints to test the IPL Fantasy local Docker backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "jwt_token",
      "value": "<paste_login_token_here>",
      "type": "string"
    },
    {
      "key": "match_id",
      "value": "<paste_cricapi_match_id>",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Google OAuth Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "google"
              ]
            },
            "description": "Generates the Google OAuth 2.0 authorization URL."
          }
        },
        {
          "name": "2. Get Current Auth Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Matches & Predictions",
      "item": [
        {
          "name": "List All Matches",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/matches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches"
              ]
            }
          }
        },
        {
          "name": "Get Specific Match & Questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/matches/{{match_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches",
                "{{match_id}}"
              ]
            }
          }
        },
        {
          "name": "Submit Match Prediction",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"match_winner\": \"CSK\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/matches/{{match_id}}/predictions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches",
                "{{match_id}}",
                "predictions"
              ]
            }
          }
        },
        {
          "name": "My Predictions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/matches/{{match_id}}/predictions/mine",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches",
                "{{match_id}}",
                "predictions",
                "mine"
              ]
            }
          }
        },
        {
          "name": "Community Predictions (Locked Only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/matches/{{match_id}}/predictions/all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches",
                "{{match_id}}",
                "predictions",
                "all"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Global Standings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leaderboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leaderboard"
              ]
            }
          }
        },
        {
          "name": "Match Specific Standings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leaderboard/match/{{match_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leaderboard",
                "match",
                "{{match_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Override",
      "item": [
        {
          "name": "View Allowlist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/allowlist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "allowlist"
              ]
            }
          }
        },
        {
          "name": "Add to Allowlist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emails\": [\n    \"new_user@example.com\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/allowlist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "allowlist"
              ]
            }
          }
        },
        {
          "name": "Remove from Allowlist",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/allowlist/new_user@example.com",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "allowlist",
                "new_user@example.com"
              ]
            }
          }
        },
        {
          "name": "Trigger Scoring & Apply Answers",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"match_winner\": \"CSK\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/matches/{{match_id}}/results",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "matches",
                "{{match_id}}",
                "results"
              ]
            }
          }
        },
        {
          "name": "Update Global Scoring JSON",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"match_winner\": {\n    \"type\": \"exact_match\",\n    \"points\": 10\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/scoring-rules",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "scoring-rules"
              ]
            }
          }
        }
      ]
    }
  ]
}
